# DB
DATABASE_URL=file:./local.db        # libsql://… (Turso) in prod

# Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sojourn-assets
R2_PUBLIC_BASE_URL=                  # https://assets.sojourn.app or https://pub-…r2.dev

# Stub source (Phase 0)
# local = serve from apps/api/fixtures/stubs/v1 via /api/stubs/v1/*
# r2    = serve from <R2_PUBLIC_BASE_URL>/stubs/v1/* (run `pnpm --filter api stubs:upload` once)
STUB_SOURCE=local                    # local | r2

# Auth & app
EDIT_KEY_PEPPER=                     # required in NODE_ENV=production; logged warning otherwise
# Origin allowed by CORS — must be the exact frontend origin (no trailing slash, no path).
# Dev (Vite proxy is same-origin, but the cors middleware still echoes this back):
#   CORS_ORIGIN=http://localhost:5173
# Production (cross-origin: Vercel frontend → Fly/Railway API):
#   CORS_ORIGIN=https://sojourn.app
# When this is set to a non-localhost origin, NODE_ENV=production also flips the
# auth cookie to SameSite=None; Secure so it survives the cross-origin hop.
# Allow-Credentials is always true (the auth cookie has to ride along).
CORS_ORIGIN=http://localhost:5173
MIGRATE_ON_BOOT=1                    # run drizzle migrations on Node startup; off in CI

# Phase 1+ placeholders (unused in Phase 0 but documented now)
PIXELLAB_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
