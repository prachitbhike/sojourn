# DB
DATABASE_URL=file:./local.db        # libsql://… (Turso) in prod

# Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sojourn-assets
R2_PUBLIC_BASE_URL=                  # https://assets.sojourn.app or https://pub-…r2.dev

# Stub source (Phase 0)
# local = serve from apps/api/fixtures/stubs/v1 via /api/stubs/v1/*
# r2    = serve from <R2_PUBLIC_BASE_URL>/stubs/v1/* (run `pnpm --filter api stubs:upload` once)
STUB_SOURCE=local                    # local | r2

# Generator selection (Phase 1)
#
# Per D08/D09/D13 the API dispatches portrait + sprite generation through two
# Generator interfaces and looks up the impl by id. These env vars set the
# *default* id used when a brand-new row is created or when no per-row override
# is recorded. Per-row overrides on `characters.portraitGenerator` / `poses.generator`
# always win over the env default.
#
# Slice 2 shipped `pixellab` (sprites) — wired into apps/api and the default.
# Slice 3 shipped `nano-banana` (portraits) as a lazy entry in
# packages/shared/src/generators/registry.ts but it is not yet wired into the
# API's buildGeneratorRegistry; PORTRAIT_GENERATOR stays `stub` until that
# integration lands. Set either to `stub` to boot without provider keys.
#
#   PORTRAIT_GENERATOR=stub         # one of: stub, nano-banana
#   SPRITE_GENERATOR=pixellab       # one of: stub, pixellab
PORTRAIT_GENERATOR=stub
SPRITE_GENERATOR=pixellab

# Auth & app
EDIT_KEY_PEPPER=                     # required in NODE_ENV=production; logged warning otherwise
# Origin allowed by CORS — must be the exact frontend origin (no trailing slash, no path).
# Dev (Vite proxy is same-origin, but the cors middleware still echoes this back):
#   CORS_ORIGIN=http://localhost:5173
# Production (cross-origin: Vercel frontend → Fly/Railway API):
#   CORS_ORIGIN=https://sojourn.app
# When this is set to a non-localhost origin, NODE_ENV=production also flips the
# auth cookie to SameSite=None; Secure so it survives the cross-origin hop.
# Allow-Credentials is always true (the auth cookie has to ride along).
CORS_ORIGIN=http://localhost:5173
MIGRATE_ON_BOOT=1                    # run drizzle migrations on Node startup; off in CI

# Phase 1+ provider keys (unused while *_GENERATOR=stub)
# PIXELLAB_API_KEY is required when SPRITE_GENERATOR=pixellab. The pixellab
# registry entry is built lazily, so leaving the key blank under
# SPRITE_GENERATOR=stub does NOT crash at boot — it only crashes if you ask
# for the real provider without a key.
PIXELLAB_API_KEY=
# Optional override for the PixelLab API base URL. Leave blank to use the
# vendor default (https://api.pixellab.ai/v1). Useful for staging mirrors or
# self-hosted proxies; tests set this to a local fake.
PIXELLAB_API_BASE=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
